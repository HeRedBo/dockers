[client]
# 客户端来源数据的默认字符集
default-character-set=utf8mb4

[mysqld]
# 服务端默认字符集
character-set-server=utf8mb4
# 连接层默认字符集
collation-server=utf8mb4_unicode_ci
# 使用时区
default-time-zone = '+8:00'

# ========== 慢查询配置（确保写在 [mysqld] 下）==========
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1
log_queries_not_using_indexes = OFF  # 不强制记录未使用索引的SQL
log_output = FILE

[mysql]
# 数据库默认字符集
default-character-set=utf8mb4

